<service>
  <id>WeighingStation</id>
  <name>SAP Weighing Station</name>
  <description>Reads the weight scale, serves the operator UI, and posts confirmations to SAP S/4HANA Public Cloud.</description>

  <executable>java</executable>
  <arguments>-jar "%BASE%\weighing-station-1.0.0.jar" --spring.config.location=file:./application.yml</arguments>

  <workingdirectory>%BASE%</workingdirectory>

  <logmode>rotate</logmode>
  <logpath>%BASE%\logs</logpath>

  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <resetfailure>1 hour</resetfailure>

  <startmode>Automatic</startmode>
</service>
